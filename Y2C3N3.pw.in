&CONTROL
    calculation = 'vc-relax'
    prefix = 'Y2C3N3_RTSC'
    pseudo_dir = './pseudo/'
    outdir = './out/'
    verbosity = 'high'
    tstress = .true.
    tprnfor = .true.
/
&SYSTEM
    ibrav = 1
    celldm(1) = 17.2721  ! 9.14 Angstrom in Bohr
    nat = 16
    ntyp = 3
    ecutwfc = 80.0
    ecutrho = 640.0
    occupations = 'smearing'
    smearing = 'marzari-vanderbilt'
    degauss = 0.02
/
&ELECTRONS
    conv_thr = 1.0d-8
    mixing_beta = 0.7
/
&IONS
    ion_dynamics = 'bfgs'
/
&CELL
    cell_dynamics = 'bfgs'
    press = 0.0
/
ATOMIC_SPECIES
    Y  88.905  Y.pbe-spn-rrkjus_psl.1.0.0.UPF
    C  12.011  C.pbe-n-rrkjus_psl.1.0.0.UPF
    N  14.007  N.pbe-n-rrkjus_psl.1.0.0.UPF

ATOMIC_POSITIONS (crystal)
Y  0.1250  0.0000  0.2500
Y  0.6250  0.5000  0.7500
C  0.3750  0.0000  0.2500
C  0.8750  0.5000  0.7500
N  0.0000  0.0000  0.0000
N  0.5000  0.5000  0.5000
! (Additional Symmetry-Generated positions pending for full 16-atom primitive cell)
K_POINTS (automatic)
  8 8 8 0 0 0
